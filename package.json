{
  "name": "rollup-plugin-pure",
  "type": "module",
  "version": "0.4.0",
  "packageManager": "pnpm@11.17.0",
  "description": "Annotate functions as pure for Rollup",
  "author": {
    "name": "Daniel Roe <daniel@roe.dev>",
    "url": "https://github.com/danielroe"
  },
  "license": "MIT",
  "repository": "danielroe/rollup-plugin-pure",
  "keywords": [
    "vite",
    "rollup",
    "pure-annotation"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev:prepare": "simple-git-hooks",
    "lint": "pnpm eslint .",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm lint && pnpm test",
    "release": "bumpp && npm publish",
    "test": "vitest run",
    "test:types": "tsc --noEmit"
  },
  "peerDependencies": {
    "rollup": "^3.0.0 || ^4.0.0"
  },
  "dependencies": {
    "estree-walker": "^3.0.3",
    "magic-string": "^0.30.17",
    "unplugin-utils": "^0.3.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "6.7.3",
    "@codspeed/vitest-plugin": "5.7.1",
    "@types/estree": "1.0.9",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "bumpp": "11.1.0",
    "eslint": "9.39.5",
    "execa": "9.6.1",
    "magic-regexp": "0.11.0",
    "nano-staged": "1.0.2",
    "pathe": "2.0.3",
    "rollup": "4.62.2",
    "simple-git-hooks": "2.13.1",
    "std-env": "4.2.0",
    "tsdown": "0.22.14",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "simple-git-hooks": {
    "pre-commit": "npx nano-staged"
  },
  "nano-staged": {
    "*": [
      "npx eslint --fix"
    ]
  }
}
